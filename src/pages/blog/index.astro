---
import { getCollection } from 'astro:content';
import HeadCommon from '../../components/HeadCommon.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);
const canonical = 'https://www.soylegal360.es/blog/';
---
<!doctype html>
<html lang="es">
<head>
  <HeadCommon />
  <title>Blog | SoyLegal360</title>
  <meta name="description" content="Artículos sobre RGPD, Reglamento de IA (AI Act) y cumplimiento legal para empresas, por el equipo de SoyLegal360." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />
  <style>
    .blog-hero{background:linear-gradient(135deg,#06142e,#102c53);color:#fff;padding:72px 22px 56px;border-bottom:7px solid #c9a96e}
    .blog-hero__wrap{width:min(900px,100%);margin:0 auto}
    .blog-hero__eyebrow{color:#c9a96e;font:800 12px/1.35 Arial,Helvetica,sans-serif;letter-spacing:.2em;text-transform:uppercase;margin:0}
    .blog-hero h1{margin:14px 0 0;font-size:clamp(32px,4.6vw,52px);line-height:1.06;color:#fff}
    .blog-hero p.lead{margin:18px 0 0;color:#cdd9ec;font:400 18px/1.5 Arial,Helvetica,sans-serif;max-width:620px}
    .blog-list{width:min(900px,100%);margin:0 auto;padding:48px 22px 72px;display:grid;gap:18px}
    .blog-card{display:block;border:1px solid rgba(23,54,97,.18);border-radius:10px;padding:26px 28px;background:#fff;box-shadow:0 16px 50px rgba(6,20,46,.06);text-decoration:none;color:#17213a;transition:transform .2s ease,border-color .2s ease,box-shadow .2s ease}
    .blog-card:hover{transform:translateY(-3px);border-color:rgba(201,169,110,.7);box-shadow:0 24px 64px rgba(6,20,46,.12)}
    .blog-card__date{margin:0;color:#5d6980;font:700 12px/1.4 Arial,Helvetica,sans-serif;letter-spacing:.06em;text-transform:uppercase}
    .blog-card h2{margin:10px 0 0;color:#06142e;font-size:25px;line-height:1.2}
    .blog-card__meta{margin:10px 0 0;color:#5d6980;font:400 16px/1.55 Arial,Helvetica,sans-serif}
    .blog-card__link{display:inline-block;margin-top:14px;color:#102c53;font:900 12px/1 Arial,Helvetica,sans-serif;letter-spacing:.08em;text-transform:uppercase}
    .blog-empty{width:min(900px,100%);margin:0 auto;padding:48px 22px;color:#5d6980}
    @media(max-width:720px){.blog-hero{padding:58px 16px 44px}.blog-list{padding:36px 16px 56px}}
  </style>
</head>
<body>
  <SiteHeader />
  <main id="contenido">
    <div class="blog-hero">
      <div class="blog-hero__wrap">
        <p class="blog-hero__eyebrow">Blog</p>
        <h1>RGPD e IA, en claro</h1>
        <p class="lead">Guías prácticas sobre protección de datos, Reglamento de IA y cumplimiento legal para empresas. Sin jerga innecesaria.</p>
      </div>
    </div>
    {posts.length === 0 ? (
      <p class="blog-empty">Aún no hay artículos publicados.</p>
    ) : (
      <section class="blog-list">
        {posts.map((post) => (
          <a class="blog-card" href={`/blog/${post.id}/`}>
            <p class="blog-card__date">{post.data.fecha.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
            <h2>{post.data.titulo}</h2>
            <p class="blog-card__meta">{post.data.meta}</p>
            <span class="blog-card__link">Leer artículo →</span>
          </a>
        ))}
      </section>
    )}
  </main>
  <SiteFooter />
</body>
</html>
