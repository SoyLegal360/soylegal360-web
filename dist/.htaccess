Options -Indexes

# ============================================================
#  CANONICAL: forzar https + www (SSL activo)
#  Redirige http://, sin www y soylegal360.es -> https://www.soylegal360.es
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.soylegal360.es%{REQUEST_URI} [R=301,L]
</IfModule>

# --- Redirects permanentes (301) ---
Redirect 301 /privacy-policy /politica-de-privacidad/
Redirect 301 /solicita-auditoria-web-gratuita /auditoria-web-gratuita/

# --- Redirect temporal (302) hasta tener casos reales ---
Redirect 302 /casos-de-exito /sobre-nosotros/

# --- Trailing slash: /ruta -> /ruta/ ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.+)$ /%{REQUEST_URI}/ [R=301,L]
</IfModule>

# --- Paginas de error ---
ErrorDocument 404 /404/index.html

# ============================================================
#  COMPRESION (Gzip) - reduce el peso de HTML/CSS/JS/SVG ~70%
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE application/rss+xml application/ld+json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ============================================================
#  CACHE DE NAVEGADOR - visitas repetidas casi instantaneas
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML: sin cache larga (para que se vean cambios al actualizar)
  ExpiresByType text/html "access plus 0 seconds"
  # CSS y JS
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-javascript "access plus 1 month"
  # Imagenes
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  # Video
  ExpiresByType video/mp4 "access plus 1 year"
  # Fuentes
  ExpiresByType font/woff2 "access plus 1 year"
  # Datos
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType application/ld+json "access plus 1 day"
</IfModule>

# ============================================================
#  CABECERAS DE SEGURIDAD (basicas, sin romper nada)
# ============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
