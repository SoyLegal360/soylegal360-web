{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "soylegal360.es" }],
      "destination": "https://www.soylegal360.es/:path*",
      "permanent": true
    },
    { "source": "/privacy-policy", "destination": "/politica-de-privacidad/", "permanent": true },
    { "source": "/privacy-policy/", "destination": "/politica-de-privacidad/", "permanent": true },
    { "source": "/solicita-auditoria-web-gratuita", "destination": "/auditoria-web-gratuita/", "permanent": true },
    { "source": "/solicita-auditoria-web-gratuita/", "destination": "/auditoria-web-gratuita/", "permanent": true },
    { "source": "/casos-de-exito", "destination": "/sobre-nosotros/", "permanent": false },
    { "source": "/casos-de-exito/", "destination": "/sobre-nosotros/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
